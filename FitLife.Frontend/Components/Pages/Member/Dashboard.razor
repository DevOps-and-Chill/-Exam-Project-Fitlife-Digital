@page "/member-dashboard"
@rendermode InteractiveServer
@layout MemberLayout
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject CurrentUserService CurrentUserService
@inject ClassService ClassService

<div class="container-fluid px-0">

    <MemberNavbar />

    <section class="container py-5">

        <div class="row align-items-center mb-5">

            <div class="col-md-7">

                <span class="badge bg-success mb-3 px-3 py-2">
                    MEDLEMSOMRÅDE
                </span>

                <h1 class="fw-bold mb-3">
                    Velkommen tilbage, @CurrentUserService.CurrentUser?.Member.GivenName
                </h1>

                <p class="lead text-muted">
                    Her kan du se dine tilmeldte hold, personlige træninger og nyheder fra dit center.
                </p>

            </div>

            <div class="col-md-5">
                <div class="bg-light border rounded-4 d-flex align-items-center justify-content-center shadow-sm"
                     style="height: 240px;">
                    <span class="text-muted">Billede fra det udvalgte center</span>
                </div>
            </div>

        </div>

        <div class="row g-4">
            
            <div class="col-md-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">

                        <div class="fs-2 mb-3">📅</div>

                        <h4 class="fw-bold mb-3">Mine tilmeldte hold</h4>

                        @foreach (var cls in MyClasses)
                        {
                            <div class="border rounded p-3 mb-3">
                                <h6 class="mb-1 fw-bold">@cls.Title</h6>
                                <p class="mb-1 text-muted">
                                    @cls.TimeStart.ToString("dd/MM") kl. @cls.TimeStart.ToString("HH:mm") - @cls.TimeEnd.ToString("HH:mm")
                                </p>
                                <p class="mb-0">
                                    Pladser: @cls.Registered.Count / @cls.MemberLimit
                                </p>
                                <button class="btn btn-outline-danger btn-sm mt-2"
                                        @onclick="() => UnregisterFromClass(cls.Id)">
                                    Afmeld
                                </button>
                            </div>
                        }
                        <a href="/find-hold" class="btn btn-success mt-2">Find flere hold</a>

                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">

                        <div class="fs-2 mb-3">💪</div>

                        <h4 class="fw-bold mb-3">Mine personlige træninger</h4>

                        @foreach (var session in PersonalTrainingSessions)
                        {
                            <div class="border rounded p-3 mb-3">
                                <h6 class="mb-1 fw-bold">@session.PersonalTrainerId</h6>
                                <p class="mb-1 text-muted">
                                    @session.StartDate.ToString("dd/MM") kl. @session.StartDate.ToString("HH:mm")
                                </p>
                                <p class="mb-0">Status: @session.Status</p>
                            </div>
                        }

                        <a href="/personal-training" class="btn btn-outline-success mt-2">Se personlig træning</a>

                    </div>
                </div>
            </div>

        </div>

        <div class="row g-4 mt-1">

            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">
                        <div class="fs-3 mb-3">👤</div>
                        <h5 class="fw-bold">Min profil</h5>
                        <p class="text-muted">Se og administrer dine medlemsoplysninger.</p>
                        <ModalProfile />
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">
                        <div class="fs-3 mb-3">💳</div>
                        <h5 class="fw-bold">Administrer medlemskab</h5>
                        <p class="text-muted">Se medlemskabstype, betaling og tilvalg.</p>
                        <ModalMemberPayment />
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">
                        <div class="fs-3 mb-3">📊</div>
                        <h5 class="fw-bold">Mine data</h5>
                        <p class="text-muted">Se træningsdata og tilkoblede wearables.</p>
                        <button class="btn btn-outline-dark" @onclick="ShowNotImplemented">Se data</button>
                    </div>
                </div>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-info mt-4">@Message</div>
        }

    </section>

    <AppFooter />

</div>

@code {

    private string Message = "";
    private List<Class> MyClasses = new();
    
    private List<PersonalTrainingSession> PersonalTrainingSessions = new();

    protected override async Task OnInitializedAsync()
    {

        var memberId = CurrentUserService.CurrentUser?.Member?.Id;

        if (!string.IsNullOrWhiteSpace(memberId))
        {
            MyClasses = await ClassService.GetClassesByMemberAsync(memberId);
        }
        //AO: Slet
        Console.WriteLine("Memberdashboard loaded");
    }
    
    private async Task UnregisterFromClass(string classId)
    {
        var memberId = CurrentUserService.CurrentUser?.Member?.Id;
        if (memberId is null) return;

        try
        {
            await ClassService.UnregisterMemberFromClassAsync(classId, memberId);
            MyClasses.RemoveAll(c => c.Id == classId);
        }
        catch
        {
            Message = "Afmelding mislykkedes. Prøv igen.";
        }
    }

    private void ShowNotImplemented()
    {
        Message = "Denne funktion er ikke implementeret endnu.";
    }


}