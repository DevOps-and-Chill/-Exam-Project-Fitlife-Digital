@page "/find-hold"
@rendermode InteractiveServer
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject ClassService ClassService
@inject CurrentUserService CurrentUserService
@inject MemberService MemberService

<div class="container-fluid px-0">

    <MemberNavbar />

    <section class="container py-5">

        <div class="mb-5">
            <span class="badge bg-success mb-3 px-3 py-2">
                HOLDTRÆNING
            </span>

            <h1 class="fw-bold mb-3">
                Find hold
            </h1>

            <p class="lead text-muted">
                Se aktuelle hold, ledige pladser og tilmeld dig direkte online.
            </p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-secondary">Filtrér</button>
                    <button class="btn btn-outline-primary">Vis alle hold</button>
                </div>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-success" role="status"></div>
                <p class="mt-3 text-muted">Henter hold...</p>
            </div>
        }
        else if (ErrorMessage is not null)
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
        else if (!Classes.Any())
        {
            <div class="alert alert-info">Ingen hold fundet.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var c in Classes)
                {
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body p-4">

                                <div class="fs-2 mb-3">📅</div>

                                <h5 class="card-title fw-bold">@c.Title</h5>

                                <p class="mb-1">
                                    <strong>Tidspunkt:</strong>
                                    @c.TimeStart.ToString("dd/MM") kl. @c.TimeStart.ToString("HH:mm")
                                </p>
                                
                                <p class="mb-1">
                                    <strong>Instruktør:</strong>
                                    @coachName
                                </p>

                                <p class="mb-3">
                                    <strong>Ledige pladser:</strong>
                                    @(c.MemberLimit - c.Registered.Count)
                                </p>

                                @if (c.Registered.Any(m => m.Id == CurrentUserId))
                                {
                                    <button class="btn btn-danger w-100"
                                            @onclick="() => Unregister(c)">
                                        Afmeld
                                    </button>
                                }
                                else if (c.Registered.Count < c.MemberLimit)
                                {
                                    <button class="btn btn-success w-100"
                                            @onclick="() => Register(c)">
                                        Tilmeld
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-warning w-100"
                                            @onclick="() => JoinWaitlist(c)">
                                        Tilmeld venteliste
                                    </button>
                                }

                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-success mt-4">@Message</div>
        }

    </section>

    <AppFooter />

</div>
@code {
    private List<Class> Classes = new();
    private string Message = "";
    private string? ErrorMessage;
    private bool IsLoading = true;
    private string CurrentUserId = Guid.NewGuid().ToString();
    private string coachName;
    private Dictionary<string, string> CoachNames = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            CurrentUserId = CurrentUserService.CurrentUser?.Id ?? string.Empty;
            Classes = await ClassService.GetAllClassesAsync();

            foreach (var c in Classes)
            {
                if (c.CoachId != string.Empty && !CoachNames.ContainsKey(c.CoachId))
                {
                    var coach = await MemberService.GetMemberByIdAsync(c.CoachId);
                    if (coach is not null)
                        CoachNames[c.CoachId] = $"{coach.GivenName} {coach.FamilyName}";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Kunne ikke hente hold: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task Register(Class c)
    {
        try
        {
            var member = new Member { Id = CurrentUserId };
            await ClassService.RegisterMemberAsync(c.Id, member);
            Message = $"Du er tilmeldt '{c.Title}'!";
            Classes = await ClassService.GetAllClassesAsync();
        }
        catch (Exception ex)
        {
            Message = $"Kunne ikke tilmelde: {ex.Message}";
        }
    }

    private async Task Unregister(Class c)
    {
        try
        {
            await ClassService.UnregisterMemberAsync(c.Id, CurrentUserId);
            Message = $"Du er afmeldt '{c.Title}'.";
            Classes = await ClassService.GetAllClassesAsync();
        }
        catch (Exception ex)
        {
            Message = $"Kunne ikke afmelde: {ex.Message}";
        }
    }

    private async Task JoinWaitlist(Class c)
    {
        try
        {
            var member = new Member { Id = CurrentUserId };
            await ClassService.JoinWaitlistAsync(c.Id, member);
            Message = $"Du er på venteliste til '{c.Title}'.";
            Classes = await ClassService.GetAllClassesAsync();
        }
        catch (Exception ex)
        {
            Message = $"Kunne ikke tilmelde venteliste: {ex.Message}";
        }
    }
}