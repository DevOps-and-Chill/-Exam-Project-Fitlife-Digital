@page "/member/personal-training"
@rendermode InteractiveServer
@layout MemberLayout
@using System.Runtime.InteropServices.JavaScript
@using FitLife.Frontend.Models
@using FitLife.Frontend.Models.DTOs
@using FitLife.Frontend.Services
@inject PTService PTService
@inject CenterService CenterService
@inject EmployeeService EmployeeService
@inject MessageService MessageService
@inject CurrentUserService CurrentUserService

<div class="container-fluid px-0">

    <!-- Shared navbar for medlemssider -->
    <MemberNavbar />

    <section class="container py-5">

        <!-- Hero/introsektion -->
        <div class="row align-items-center mb-5">

            <div class="col-md-7">

                <span class="badge bg-success mb-3 px-3 py-2">
                    PERSONLIG TRÆNING
                </span>

                <h1 class="fw-bold mb-3">
                    Personlig træning
                </h1>

                <p class="lead text-muted">
                    Find en personlig træner, book en session eller send en besked direkte fra platformen.
                </p>

            </div>

            <!-- Placeholder til billede -->
            <!-- TODO:
                 Senere kan billedet hentes dynamisk fra backend eller CMS -->
            <div class="col-md-5">

                <div class="bg-light border rounded-4 d-flex align-items-center justify-content-center shadow-sm"
                     style="height: 240px;">

                    <span class="text-muted">
                        Billede fra det udvalgte center
                    </span>

                </div>

            </div>
        </div>

        <!-- Liste over trænere -->
        <div class="row g-4">

            <!-- Loop gennem alle trænere -->
            <!-- Trænere hentes fra UserService via TrainerService -->
            @foreach (var trainer in Trainers)
            {
                <div class="col-md-4">

                    <div class="card shadow-sm h-100 border-0">

                        <div class="card-body p-4">

                            <div class="fs-2 mb-3">
                                💪
                            </div>

                            <h4 class="fw-bold">
                                @trainer.GivenName
                            </h4>

                            <p class="text-muted">
                                @trainer.Description
                            </p>
                            
                            
                            <p class="mb-3">

                                <strong>Ledig:</strong>

                                @(trainer.IsAvailable ? "Ja" : "Nej")
                            </p>

                            <div class="d-grid gap-2">

                                <!-- Hvis træneren er ledig kan medlemmet booke -->
                                @if (trainer.IsAvailable)
                                {
                                    <button class="btn btn-success"
                                            @onclick="() => SelectTrainerForBooking(trainer)">
                                        Book session
                                    </button>
                                }
                                else
                                {
                                    <!-- Hvis træneren ikke er ledig -->
                                    <button class="btn btn-warning"
                                            @onclick="() => JoinWaitlist(trainer)">
                                        Tilmeld venteliste
                                    </button>
                                }

                                <!-- Åbner beskedformular -->
                                <button class="btn btn-outline-dark"
                                        @onclick="() => SelectTrainerForMessage(trainer)">
                                    Send besked
                                </button>

                                <!-- Midlertidig prototype-knap -->
                                <!-- TODO:
                                     Kan senere navigere til separat profilside -->
                                <button class="btn btn-outline-secondary"
                                        @onclick="() => ShowProfile(trainer)">
                                    Se profil
                                </button>

                            </div>

                        </div>
                    </div>
                </div>
            }

        </div>

        <!-- Bookingpanel -->
        @if (SelectedEmployeeForBooking is not null)
        {
            <div class="card shadow-sm border-0 mt-5">

                <div class="card-body p-4">

                    <h4 class="fw-bold">
                        Book session med @SelectedEmployeeForBooking.GivenName
                    </h4>

                    <p class="text-muted">
                        Vælg center, dato og tidspunkt for din personlige træning.
                    </p>

                    <div class="row g-3 mt-2">

                        <!-- Valg af center -->
                        <!-- Centre hentes fra FacilityService via CenterService -->
                        <div class="col-md-12">

                            <label class="form-label">
                                Vælg center
                            </label>

                            <select class="form-select"
                                    @bind="SelectedCenterId">

                                <option value="">
                                    Vælg center
                                </option>

                                @foreach (var center in Centers)
                                {
                                    <option value="@center.Id">
                                        @center.Name - @center.Address
                                    </option>
                                }

                            </select>

                        </div>

                        <!-- Valg af dato -->
                        <div class="col-md-6">

                            <label class="form-label">
                                Valgt dato
                            </label>

                            <input class="form-control"
                                   type="date"
                                   @bind="SelectedDate" />
                        </div>

                        <!-- Valg af tidspunkt -->
                        <div class="col-md-6">

                            <label class="form-label">
                                Vælg tid
                            </label>

                            <select class="form-select"
                                    @bind="SelectedTime">

                                <option value="">
                                    Vælg tid
                                </option>

                                <option>09:00</option>
                                <option>12:00</option>
                                <option>15:00</option>
                                <option>17:00</option>

                            </select>

                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">

                        <!-- Opretter booking -->
                        <!-- Sender booking til PTService/API -->
                        <button class="btn btn-success"
                                @onclick="BookSession">
                            Book
                        </button>

                        <!-- Lukker booking -->
                        <button class="btn btn-outline-secondary"
                                @onclick="CancelBooking">
                            Afbryd booking
                        </button>

                    </div>

                </div>
            </div>
        }

        <!-- Beskedpanel -->
@if (SelectedEmployeeForMessage is not null)
{
    <div class="card shadow-sm border-0 mt-5">

        <div class="card-body p-4">

            <h4 class="fw-bold">
                Send besked til @SelectedEmployeeForMessage.GivenName
            </h4>

            <p class="text-muted">
                Skriv en kort besked til træneren om dit behov eller spørgsmål.
            </p>

            <!-- Message-modellen bruges nu i stedet for separate strings -->
            <!-- Dette gør løsningen mere domain-driven og nemmere at koble til backend -->

            <div class="mb-3">

                <label class="form-label">
                    Emne
                </label>

                <input class="form-control"
                       @bind="NewMessage.Subject" />
            </div>

            <div class="mb-3">

                <label class="form-label">
                    Besked
                </label>

                <textarea class="form-control"
                          rows="5"
                          @bind="NewMessage.Content">
                </textarea>

            </div>

            <div class="d-flex gap-3">

                <!-- Sender besked -->
                <!-- TODO:
                     Senere skal beskeden gemmes via MessageService/API -->
                <button class="btn btn-success"
                        @onclick="SendMessage">
                    Send
                </button>

                <!-- Lukker beskedformular -->
                <button class="btn btn-outline-secondary"
                        @onclick="CancelMessage">
                    Afbryd
                </button>

            </div>

        </div>
    </div>
}

        <!-- Feedback til bruger -->
        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-info mt-4">
                @StatusMessage
            </div>
        }

    </section>

    <AppFooter />

</div>

@code {

    // Holder styr på hvilken træner brugeren vil booke hos
    private Employee? SelectedEmployeeForBooking;

    // Holder styr på hvilken træner brugeren skriver til
    private Employee? SelectedEmployeeForMessage;

    // Midlertidige bookingfelter
    private DateTime? SelectedDate;
    private string SelectedTime = "";

    // Liste over centre hentet fra FacilityService
    // TODO:
    // Senere kan valgt center evt. komme fra brugerens profil eller valgte center i navigationen
    private List<ExerciseGym> Centers = new();

    private string SelectedCenterId = "";

    // Message-model bruges til beskedsystemet
    // TODO:
    // Skal senere sendes til backend via MessageService/API
    private DirectMessageDto NewMessage = new();

    // Feedback til bruger
    private string StatusMessage = "";

    // Trænere hentes fra UserService
    // TODO:
    // Senere kan data udvides med speciale, profiltekst og bookingkalender
    private List<Employee> Trainers = new();

    // Henter centre og trænere når siden indlæses
    protected override async Task OnInitializedAsync()
    {
        try
        {
            Centers = await CenterService.GetCentersAsync();
            
            SelectedCenterId = Centers.FirstOrDefault()?.Id ?? "";
            
            await CurrentUserService.SetCurrentUser();

            var member = CurrentUserService.CurrentUser?.Member;
            
            var affiliationId = member.Affiliation;
            
            Trainers = await EmployeeService.GetEmployeesByAffiliationAsync(affiliationId);
        }
        catch (Exception ex)
        {
            StatusMessage = $"Kunne ikke hente data: {ex.Message}";
        }
    }

    // Åbner bookingpanel
    private void SelectTrainerForBooking(Employee trainer)
    {
        SelectedEmployeeForBooking = trainer;

        // Lukker eventuel beskedformular
        SelectedEmployeeForMessage = null;

        StatusMessage = "";
    }

    // Åbner beskedformular
    private void SelectTrainerForMessage(Employee trainer)
    {
        SelectedEmployeeForMessage = trainer;

        // Lukker eventuel booking
        SelectedEmployeeForBooking = null;

        StatusMessage = "";

        // Nulstiller besked
        NewMessage = new DirectMessageDto();
    }

    // Midlertidig ventelistefunktion
    // TODO:
    // Skal senere kobles til backend
    private void JoinWaitlist(Employee trainer)
    {
        StatusMessage = $"Du er nu tilmeldt ventelisten hos {trainer.GivenName}.";
    }

    // Midlertidig prototypefunktion
    private void ShowProfile(Employee trainer)
    {
        StatusMessage = $"Profil for {trainer.GivenName} vises ikke som separat side endnu.";
    }

    // Opretter booking
    // Sender booking til PTService/API
    private async Task BookSession()
    {
        if (SelectedEmployeeForBooking is null ||
            SelectedDate is null ||
            string.IsNullOrWhiteSpace(SelectedTime) ||
            string.IsNullOrWhiteSpace(SelectedCenterId))
        {
            StatusMessage = "Vælg både center, dato og tid.";
            return;
        }

        if (!Guid.TryParse(SelectedCenterId, out var centerId))
        {
            StatusMessage = "Det valgte center har ikke et gyldigt Guid-id.";
            return;
        }

        if (!Guid.TryParse(SelectedEmployeeForBooking.Id, out var trainerId))
        {
            StatusMessage = "Den valgte træner har ikke et gyldigt Guid-id.";
            return;
        }

        if (!TimeSpan.TryParse(SelectedTime, out var selectedTime))
        {
            StatusMessage = "Tidspunktet er ugyldigt.";
            return;
        }

        var startDate = SelectedDate.Value.Date.Add(selectedTime);

        var newSession = new PersonalTrainingSession
        {
            // Midlertidigt member-id
            // TODO:
            // Senere skal MemberId hentes fra den bruger der er logget ind
            MemberId = Guid.Parse("11111111-1111-1111-1111-111111111111"),

            // PersonalTrainerId kommer fra UserService via den valgte træner
            PersonalTrainerId = trainerId,

            // CenterId kommer fra FacilityService via det valgte center
            CenterId = centerId,

            // Midlertidigt mål
            // TODO:
            // Senere kan brugeren selv vælge mål, fx vægttab, styrke eller kondition
            Goal = 0,

            StartDate = startDate,

            EndDate = startDate.AddHours(1)
        };

        var bookedSession = await PTService.BookSessionAsync(newSession);

        if (bookedSession is null)
        {
            StatusMessage = "Bookingen kunne ikke oprettes. Tjek at PTService kører.";
            return;
        }

        StatusMessage =
            $"Du har booket en session med {SelectedEmployeeForBooking.GivenName} den {SelectedDate:dd/MM} kl. {SelectedTime}.";

        // Lukker bookingpanel og nulstiller data
        SelectedEmployeeForBooking = null;
        SelectedDate = null;
        SelectedTime = "";
    }

    // Lukker bookingformular
    private void CancelBooking()
    {
        SelectedEmployeeForBooking = null;
        SelectedDate = null;
        SelectedTime = "";
    }

    // Sender besked
    private async Task SendMessage()
    {
        if (SelectedEmployeeForMessage is null ||
            string.IsNullOrWhiteSpace(NewMessage.Subject) ||
            string.IsNullOrWhiteSpace(NewMessage.Content))
        {
            StatusMessage = "Udfyld både emne og besked.";
            return;
        }

        try
        {
            var senderId = CurrentUserService.CurrentUser?.GetId();

            var dto = new DirectMessageDto
            {
                SenderId = senderId,
                ReceiverId = SelectedEmployeeForMessage.Id,
                Subject = NewMessage.Subject,
                Content = NewMessage.Content,
            };

            await MessageService.SendDirectMessageAsync(dto);

            StatusMessage = $"Din besked til {SelectedEmployeeForMessage.GivenName} er sendt.";
            SelectedEmployeeForMessage = null;
            NewMessage = new DirectMessageDto();
        }
        catch
        {
            StatusMessage = "Beskeden kunne ikke sendes. Prøv igen.";
        }
    }
    private void CancelMessage()
    {
        SelectedEmployeeForMessage = null;

        NewMessage = new DirectMessageDto();
    }
}