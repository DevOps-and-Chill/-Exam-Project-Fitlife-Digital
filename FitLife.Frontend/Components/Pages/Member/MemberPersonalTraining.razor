@page "/member/personal-training"
@rendermode InteractiveServer
@layout MemberLayout
@using FitLife.Frontend.Models
@using FitLife.Frontend.Models.DTOs
@using FitLife.Frontend.Services
@inject PTService PTService
@inject CenterService CenterService
@inject EmployeeService EmployeeService
@inject MessageService MessageService
@inject CurrentUserService CurrentUserService


<div class="container-fluid px-0">

    <MemberNavbar />

    <section class="container py-5">

        <div class="row align-items-center mb-5">
            <div class="col-md-7">
                <span class="badge bg-success mb-3 px-3 py-2">PERSONLIG TRÆNING</span>
                <h1 class="fw-bold mb-3">Personlig træning</h1>
                <p class="lead text-muted">Find en personlig træner, book en session eller send en besked direkte fra platformen.</p>
            </div>
            <div class="col-md-5">
                <div class="bg-light border rounded-4 d-flex align-items-center justify-content-center shadow-sm" style="height: 240px;">
                    <span class="text-muted">Billede fra det udvalgte center</span>
                </div>
            </div>
        </div>

        <!-- Liste over trænere -->
        <div class="row g-4">
            @foreach (var trainer in Trainers)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100 border-0">
                        <div class="card-body p-4">
                            <div class="fs-2 mb-3">💪</div>
                            <h4 class="fw-bold">@trainer.GivenName @trainer.FamilyName</h4>
                            <p class="mb-3"><strong>Rolle:</strong> @trainer.EmployeeRoleName</p>
                            <p class="mb-3"><strong>PT:</strong> @(trainer.IsPT ? "Ja" : "Nej")</p>

                            <div class="d-grid gap-2">
                                <button class="btn btn-success"
                                        @onclick="() => SelectTrainerForBooking(trainer)">
                                    Book session
                                </button>

                                <button class="btn btn-outline-dark"
                                        @onclick="() => SelectTrainerForMessage(trainer)">
                                    Send besked
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Mine PT-sessioner -->
        <div class="mb-5 mt-5">
            <h3 class="fw-bold mb-4">Mine sessioner</h3>

            @if (IsLoading)
            {
                <div class="alert alert-info">Henter sessioner...</div>
            }
            else if (Sessions.Count == 0)
            {
                <div class="alert alert-secondary">Du har ingen PT-sessioner endnu.</div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var session in Sessions)
                    {
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="fw-bold mb-0">PT Session</h5>
                                        <span class="badge @GetStatusBadgeClass(session.Status)">@GetStatusText(session.Status)</span>
                                    </div>
                                    <p class="mb-1"><strong>Start:</strong> @session.StartDate.ToString("dd/MM/yyyy HH:mm")</p>
                                    <p class="mb-1"><strong>Slut:</strong> @session.EndDate.ToString("dd/MM/yyyy HH:mm")</p>
                                    <p class="mb-3"><strong>Oprettet:</strong> @session.CreatedDate.ToString("dd/MM/yyyy")</p>

                                    @if (session.Status == 0)
                                    {
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => CancelSession(session)">
                                            Annuller session
                                        </button>

                                        <button class="btn btn-outline-dark btn-sm mt-2"
                                                @onclick="() => SelectTrainerForMessageFromSession(session)">
                                            Send besked til træner
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    
        <!-- Mine PT-sessioner -->
        <div class="mb-5 mt-5">
            <h3 class="fw-bold mb-4">Mine sessioner</h3>

            @if (IsLoading)
            {
                <div class="alert alert-info">Henter sessioner...</div>
            }
            else if (Sessions.Count == 0)
            {
                <div class="alert alert-secondary">Du har ingen PT-sessioner endnu.</div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var session in Sessions)
                    {
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-body p-4">

                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                            <h5 class="fw-bold mb-0">PT Session</h5>
                                        <span class="badge @GetStatusBadgeClass(session.Status)">
                                            @GetStatusText(session.Status)
                                        </span>
                                    </div>

                                    <p class="mb-1"><strong>Start:</strong> @session.StartDate.ToString("dd/MM/yyyy HH:mm")</p>
                                    <p class="mb-1"><strong>Slut:</strong> @session.EndDate.ToString("dd/MM/yyyy HH:mm")</p>
                                    <p class="mb-3"><strong>Oprettet:</strong> @session.CreatedDate.ToString("dd/MM/yyyy")</p>

                                    @if (session.Status == 0)
                                    {
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => CancelSession(session)">
                                            Annuller session
                                        </button>
                                    
                                        <button class="btn btn-outline-dark btn-sm mt-2"
                                                @onclick="() => SelectTrainerForMessageFromSession(session)">
                                            Send besked til træner
                                        </button>
                                    }

                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Bookingpanel -->
        @if (SelectedEmployeeForBooking is not null)
        {
            <div class="card shadow-sm border-0 mt-5">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Book session med @SelectedEmployeeForBooking.GivenName @SelectedEmployeeForBooking.FamilyName</h4>
                    <p class="text-muted">Vælg center, dato og tidspunkt for din personlige træning.</p>

                    <div class="row g-3 mt-2">
                        <div class="col-md-12">
                            <label class="form-label">Vælg center</label>
                            <select class="form-select" @bind="SelectedCenterId">
                                <option value="">Vælg center</option>
                                @foreach (var center in Centers)
                                {
                                    <option value="@center.Id">@center.Name - @center.Address</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Valgt dato</label>
                            <input class="form-control" type="date" @bind="SelectedDate" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Vælg tid</label>
                            <select class="form-select" @bind="SelectedTime">
                                <option value="">Vælg tid</option>
                                <option>09:00</option>
                                <option>12:00</option>
                                <option>15:00</option>
                                <option>17:00</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button class="btn btn-success" @onclick="BookSession">Book</button>
                        <button class="btn btn-outline-secondary" @onclick="CancelBooking">Afbryd booking</button>
                    </div>
                </div>
            </div>
        }

        <!-- Beskedpanel -->
        @if (SelectedEmployeeForMessage is not null)
        {
            <div class="card shadow-sm border-0 mt-5">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Send besked til @SelectedEmployeeForMessage.GivenName @SelectedEmployeeForMessage.FamilyName</h4>
                    <p class="text-muted">Skriv en kort besked til træneren om dit behov eller spørgsmål.</p>

                    <div class="mb-3">
                        <label class="form-label">Emne</label>
                        <input class="form-control" @bind="NewMessage.Subject" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Besked</label>
                        <textarea class="form-control" rows="5" @bind="NewMessage.Content"></textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <button class="btn btn-success" @onclick="SendMessage">Send</button>
                        <button class="btn btn-outline-secondary" @onclick="CancelMessage">Afbryd</button>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-info mt-4">@StatusMessage</div>
        }

    </section>

    <AppFooter />

</div>

@code {
    private Employee? SelectedEmployeeForBooking;
    private Employee? SelectedEmployeeForMessage;
    private DateTime? SelectedDate;
    private string SelectedTime = "";
    private List<ExerciseGym> Centers = new();
    private string SelectedCenterId = "";
    private Message NewMessage = new();
    private string StatusMessage = "";
    private List<Employee> Trainers = new();
    private List<PersonalTrainingSession> Sessions = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Centers = await CenterService.GetCentersAsync();
            SelectedCenterId = Centers.FirstOrDefault()?.Id ?? "";
            Trainers = await EmployeeService.GetAllEmployeesAsync();
            Sessions = await PTService.GetSessionsAsync();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Kunne ikke hente data: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CancelSession(PersonalTrainingSession session)
    {
        var success = await PTService.CancelSessionAsync(session.Id);
        if (success)
        {
            StatusMessage = "Session annulleret.";
            Sessions = await PTService.GetSessionsAsync();
        }
        else
        {
            StatusMessage = "Kunne ikke annullere sessionen.";
        }
    }

    private async Task SelectTrainerForMessageFromSession(PersonalTrainingSession session)
    {
        try
        {
            var trainer = await EmployeeService.GetEmployeeByIdAsync(session.PersonalTrainerId.ToString());
            if (trainer is not null)
            {
                SelectedEmployeeForMessage = trainer;
                NewMessage = new Message();
                StatusMessage = "";
            }
        }
        catch
        {
            StatusMessage = "Kunne ikke finde træneren.";
        }
    }

    private string GetStatusBadgeClass(int status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-primary",
        2 => "bg-success",
        3 => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetStatusText(int status) => status switch
    {
        0 => "Afventer",
        1 => "Aktiv",
        2 => "Gennemført",
        3 => "Annulleret",
        _ => "Ukendt"
    };

    private void SelectTrainerForBooking(Employee trainer)
    {
        SelectedEmployeeForBooking = trainer;
        SelectedEmployeeForMessage = null;
        StatusMessage = "";
    }

    private void SelectTrainerForMessage(Employee trainer)
    {
        SelectedEmployeeForMessage = trainer;
        SelectedEmployeeForBooking = null;
        StatusMessage = "";
        NewMessage = new Message();
    }

    private async Task BookSession()
    {
        if (SelectedEmployeeForBooking is null ||
            SelectedDate is null ||
            string.IsNullOrWhiteSpace(SelectedTime) ||
            string.IsNullOrWhiteSpace(SelectedCenterId))
        {
            StatusMessage = "Vælg både center, dato og tid.";
            return;
        }

        if (!Guid.TryParse(SelectedCenterId, out var centerId))
        {
            StatusMessage = "Det valgte center har ikke et gyldigt Guid-id.";
            return;
        }

        if (!Guid.TryParse(SelectedEmployeeForBooking.Id, out var trainerId))
        {
            StatusMessage = "Den valgte træner har ikke et gyldigt Guid-id.";
            return;
        }

        if (!TimeSpan.TryParse(SelectedTime, out var selectedTime))
        {
            StatusMessage = "Tidspunktet er ugyldigt.";
            return;
        }

        var startDate = SelectedDate.Value.Date.Add(selectedTime);

        var newSession = new PersonalTrainingSession
        {
            MemberId = Guid.Parse("11111111-1111-1111-1111-111111111111"), // TODO: hent fra CurrentUserService
            PersonalTrainerId = trainerId,
            CenterId = centerId,
            Goal = 0,
            StartDate = startDate,
            EndDate = startDate.AddHours(1)
        };

        var bookedSession = await PTService.BookSessionAsync(newSession);

        if (bookedSession is null)
        {
            StatusMessage = "Bookingen kunne ikke oprettes. Tjek at PTService kører.";
            return;
        }

        StatusMessage = $"Du har booket en session med {SelectedEmployeeForBooking.GivenName} {SelectedEmployeeForBooking.FamilyName} den {SelectedDate:dd/MM} kl. {SelectedTime}.";
        SelectedEmployeeForBooking = null;
        SelectedDate = null;
        SelectedTime = "";
    }

    private void CancelBooking()
    {
        SelectedEmployeeForBooking = null;
        SelectedDate = null;
        SelectedTime = "";
    }

    private async Task SendMessage()
    {
        if (SelectedEmployeeForMessage is null ||
            string.IsNullOrWhiteSpace(NewMessage.Subject) ||
            string.IsNullOrWhiteSpace(NewMessage.Content))
        {
            StatusMessage = "Udfyld både emne og besked.";
            return;
        }

        try
        {
            var senderId = CurrentUserService.CurrentUser?.GetId();

            var dto = new DirectMessageDto
            {
                SenderId = senderId,
                ReceiverId = SelectedEmployeeForMessage.Id,
                Subject = NewMessage.Subject,
                Content = NewMessage.Content,
                Timestamp = DateTime.UtcNow
            };

            await MessageService.SendDirectMessageAsync(dto);

            StatusMessage = $"Din besked til {SelectedEmployeeForMessage.GivenName} {SelectedEmployeeForMessage.FamilyName} er sendt.";
            SelectedEmployeeForMessage = null;
            NewMessage = new Message();
        }
        catch
        {
            StatusMessage = "Beskeden kunne ikke sendes. Prøv igen.";
        }
    }

    private void CancelMessage()
    {
        SelectedEmployeeForMessage = null;
        NewMessage = new Message();
    }
}
