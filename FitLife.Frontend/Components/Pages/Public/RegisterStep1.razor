@page "/register-step1"
@rendermode InteractiveServer

<div class="container-fluid px-0">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-5 py-3">
        <a class="navbar-brand fw-bold fs-3" href="/">FitLife</a>

        <div class="ms-auto d-flex align-items-center gap-3">
            <a class="nav-link" href="/">Find center</a>
            <a class="nav-link" href="/find-hold">Find hold</a>
            <a class="nav-link" href="/personal-training">Personlig træning</a>
            <a class="nav-link" href="/digital-training">Digital træning</a>
            <a class="nav-link" href="/login">Login</a>
            <a class="btn btn-success fw-bold px-4" href="/register-step1">BLIV MEDLEM</a>
        </div>
    </nav>

    <section class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Opret medlemskab</h2>
            <button class="btn btn-outline-secondary">Hjælp mig</button>
        </div>

        <div class="row mb-4 text-center">
            <div class="col">
                <div class="border rounded p-3 bg-success text-white">
                    Trin 1<br />
                    Personlige informationer
                </div>
            </div>

            <div class="col">
                <div class="border rounded p-3 bg-light">
                    Trin 2<br />
                    Vælg medlemskabstype
                </div>
            </div>

            <div class="col">
                <div class="border rounded p-3 bg-light">
                    Trin 3<br />
                    Betalingsoplysninger
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Fornavn</label>
                        <input class="form-control" @bind="FirstName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Efternavn</label>
                        <input class="form-control" @bind="LastName" />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Adresse</label>
                        <input class="form-control" @bind="Address" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Postnr.</label>
                        <input class="form-control" @bind="PostalCode" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">By</label>
                        <input class="form-control" @bind="City" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Fødselsdag</label>
                        <input class="form-control" type="date" @bind="BirthDate" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">E-mailadresse</label>
                        <input class="form-control" type="email" @bind="Email" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Telefonnummer</label>
                        <input class="form-control" @bind="PhoneNumber" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input class="form-control" type="password" @bind="Password" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Gentag password</label>
                        <input class="form-control" type="password" @bind="RepeatPassword" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="alert alert-warning mt-4">
                        @Message
                    </div>
                }

                <div class="d-flex justify-content-between mt-4">
                    <a href="/" class="btn btn-outline-secondary">
                        Tilbage
                    </a>

                    <button class="btn btn-success px-4" @onclick="GoToNextStep">
                        Næste
                    </button>
                </div>

            </div>
        </div>

    </section>

    <footer class="border-top bg-light py-4 text-center text-muted">
        Footer
    </footer>

</div>

@code {
    private string FirstName = "";
    private string LastName = "";
    private string Address = "";
    private string PostalCode = "";
    private string City = "";
    private DateTime? BirthDate;
    private string Email = "";
    private string PhoneNumber = "";
    private string Password = "";
    private string RepeatPassword = "";
    private string Message = "";

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private void GoToNextStep()
    {
        if (string.IsNullOrWhiteSpace(FirstName) ||
            string.IsNullOrWhiteSpace(LastName) ||
            string.IsNullOrWhiteSpace(Email))
        {
            Message = "Udfyld som minimum fornavn, efternavn og email.";
            return;
        }

        if (Password != RepeatPassword)
        {
            Message = "Password og gentag password skal være ens.";
            return;
        }

        Navigation.NavigateTo("/register-step2");
    }
}