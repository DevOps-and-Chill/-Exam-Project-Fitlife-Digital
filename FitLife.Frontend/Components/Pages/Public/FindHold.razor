@page "/find-hold"
@rendermode InteractiveServer
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject ClassService ClassService

<div class="container-fluid px-0">

    <PublicNavbar />

    <section class="container py-5">

        <div class="mb-5">
            <h1 class="fw-bold mb-3">
                Find hold
            </h1>

            <p class="lead text-muted">
                Se hvilke hold FitLife tilbyder på tværs af kæden, inden du melder dig ind.
            </p>
        </div>

        <div class="row g-4">

            @foreach (var classModel in Classes)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body p-4">

                            <h4 class="fw-bold">
                                @classModel.Title
                            </h4>

                            <p class="mb-0">
                                <strong>Center:</strong>
                                FitLife center
                            </p>

                        </div>
                    </div>
                </div>
            }

        </div>

    </section>

    <AppFooter />

</div>

@code {
    private List<Class> Classes = new();

    protected override async Task OnInitializedAsync()
    {
        string exerciseGymId = "";
        Classes = await ClassService.GetClassesByExerciseGymAsync(exerciseGymId);
    }
}