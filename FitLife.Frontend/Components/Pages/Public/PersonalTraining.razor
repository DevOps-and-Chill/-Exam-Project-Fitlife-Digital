@page "/personal-training"
@rendermode InteractiveServer

<div class="container-fluid px-0">

    <PublicNavbar />

    <section class="container py-5">

        <div class="mb-5">
            <h1 class="fw-bold mb-3">
                Personlig træning
            </h1>

            <p class="lead text-muted">
                Få individuel vejledning, struktur og motivation med en personlig træner hos FitLife.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Opstart og mål</h4>
                        <p class="text-muted">
                            En personlig træner hjælper dig med at sætte realistiske mål og lave en plan,
                            der passer til dit niveau og din hverdag.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Teknik og øvelser</h4>
                        <p class="text-muted">
                            Få hjælp til korrekt teknik, sikre øvelser og bedre forståelse af din træning.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Løbende motivation</h4>
                        <p class="text-muted">
                            Træneren følger op på din udvikling og hjælper dig med at holde fast i dine vaner.
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <div class="alert alert-info mt-5">
            Som medlem kan du booke personlig træning direkte fra din medlemsside.
        </div>

    </section>

    <AppFooter />

</div>