@page "/digital-training"
@rendermode InteractiveServer

<div class="container-fluid px-0">

    <MemberNavbar />
    @*//TODO: Add check for member.MembershipType == "Premium" since only premium members are able to see digital training,
        maybe add the check to PublicNavbar or NavMenu instead so that the navlink isn't available if member.MembershipType != "Premium"

    *@
    <section class="container py-5">

        <div class="mb-5">
            <h1 class="fw-bold mb-3">
                Digital træning
            </h1>

            <p class="lead text-muted">
                Træn hvor og hvornår det passer dig med digitale træningsmuligheder fra FitLife.
            </p>
        </div>

        <div class="row g-4 mb-5">

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">
                            Hjemmetræning
                        </h4>

                        <p class="text-muted">
                            Få adgang til korte og effektive træningspas, som kan udføres hjemme
                            uden behov for avanceret udstyr.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">
                            Mobilitet og recovery
                        </h4>

                        <p class="text-muted">
                            Brug digitale øvelser til udstrækning, restitution og bedre bevægelighed
                            som supplement til din almindelige træning.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">
                            Programmer og challenges
                        </h4>

                        <p class="text-muted">
                            Følg simple træningsforløb og challenges, der kan hjælpe dig med at skabe
                            struktur og holde motivationen oppe.
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <div class="card border-0 shadow-sm mb-5">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-3">
                    Et fleksibelt supplement til centertræning
                </h3>

                <p class="text-muted mb-0">
                    Digital træning er tænkt som et supplement til FitLifes fysiske centre.
                    Det giver medlemmer mulighed for at fortsætte træningen hjemme, på farten
                    eller mellem besøg i centeret.
                </p>
            </div>
        </div>

        <div class="alert alert-info">
            Som medlem får du adgang til FitLifes digitale træningsunivers direkte fra din medlemsside.
        </div>

    </section>

    <AppFooter />

</div>