@page "/login"
@rendermode InteractiveServer
@using FitLife.Frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject CurrentUserService CurrentUserService

<div class="container-fluid px-0">

    <!-- Shared navbar for public pages -->
    <PublicNavbar />

    <section class="container py-5">

        <div class="row align-items-center">

            <!-- Placeholder til billede -->
            <!-- TODO:
                 Senere kan dette erstattes med rigtigt billede/video fra backend eller CMS -->
            <div class="col-md-6">

                <div class="border bg-light d-flex align-items-center justify-content-center"
                     style="height: 420px;">

                    <span class="text-muted fs-5">
                        Inspirerende billede fra et center
                    </span>

                </div>

            </div>

            <!-- Loginformular -->
            <div class="col-md-5 offset-md-1">

                <h2 class="mb-4">
                    LOGIN
                </h2>

                <!-- Email-input -->
                <!-- @bind kobler inputfeltet direkte til Email-variablen -->
                <div class="mb-3">

                    <label class="form-label">
                        Email
                    </label>

                    <input class="form-control"
                           type="email"
                           @bind="Email" />
                </div>

                <!-- Password-input -->
                <!-- Password skjules automatisk pga type="password" -->
                <div class="mb-4">

                    <label class="form-label">
                        Password
                    </label>

                    <input class="form-control"
                           type="password"
                           @bind="Password" />
                </div>

                <div class="d-grid gap-3">

                    <!-- Starter loginprocessen -->
                    <!-- Kalder AuthServiceAPI via frontend AuthService -->
                    <button class="btn btn-success"
                            @onclick="LoginUser">
                        LOGIN
                    </button>

                    <!-- Prototype-knap -->
                    <!-- TODO:
                         Kan senere kobles til password reset eller support -->
                    <button class="btn btn-outline-secondary">
                        Få hjælp til login
                    </button>

                </div>

                <!-- Feedback til bruger -->
                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="alert alert-info mt-4">
                        @Message
                    </div>
                }

            </div>

        </div>

    </section>

    <AppFooter />

</div>

@code {

    // Gemmer brugerens email fra loginformularen
    private string Email = "";

    // Gemmer brugerens password fra loginformularen
    private string Password = "";

    // Bruges til feedbackbeskeder i UI'et
    private string Message = "";

   private async Task LoginUser()
    {
        var result = await AuthService.LoginAsync(Email, Password);

        Message = result.Message;

        if (!result.Success)
        {
            return;
        }
        await CurrentUserService.SetCurrentUser();

        if (CurrentUserService.CurrentUser?.GetUserType() == "member")
        {
            Navigation.NavigateTo("/member-dashboard");
        }
        else if (CurrentUserService.CurrentUser?.GetUserType() == "employee")
        {
            Navigation.NavigateTo("/employee-dashboard");
        }
        else
        {
            Message = "Ukendt brugerrolle.";
        }
    }
}