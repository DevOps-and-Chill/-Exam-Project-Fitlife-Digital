@page "/find-center"
@rendermode InteractiveServer
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject CenterService CenterService

<div class="container-fluid px-0">

    <PublicNavbar />

    <section class="container py-5">

        <div class="mb-5">
            <h1 class="fw-bold mb-3">
                Find center
            </h1>

            <p class="lead text-muted">
                Se FitLife-centre, adresser og vælg det center der passer bedst til dig.
            </p>
        </div>

        @if (IsLoadingCenters)
        {
            <p class="text-muted">Indlæser centre...</p>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="alert alert-warning">
                @ErrorMessage
            </div>
        }
        else if (!Centers.Any())
        {
            <p class="text-muted">Der er ingen centre at vise lige nu.</p>
        }
        else
        {
            <div class="row g-4">
                <h3>Vores træningscentre</h3>
                @foreach (var center in Centers.FindAll(sp => sp.GetType() == typeof(ExerciseGym)))
                {
                    <div class="col-md-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body p-4">

                                <h4 class="fw-bold">
                                    @center.Name
                                </h4>

                                <p class="text-muted mb-1">
                                    @center.Address
                                </p>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-success"
                                            @onclick="() => SelectCenter(center)">
                                        Vælg center
                                    </button>

                                    <a href="/find-hold" class="btn btn-outline-secondary">
                                        Se hold
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }

            </div>
            <div class="row g-4">
                <h3>Svømmehaller vi samarbejder med:</h3>
                @foreach (var center in Centers.FindAll(sp => sp.GetType() == typeof (SwimmingPool)))
                {
                    <div class="col-md-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body p-4">

                                <h4 class="fw-bold">
                                    @center.Name
                                </h4>

                                <p class="text-muted mb-1">
                                    @center.Address
                                </p>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-success"
                                            @onclick="() => SelectCenter(center)">
                                        Vælg center
                                    </button>

                                    <a href="/find-hold" class="btn btn-outline-secondary">
                                        Se hold
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }

            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-info mt-4">
                @Message
            </div>
        }

    </section>

    <AppFooter />

</div>

@code {
    private List<Facility> Centers = new();

    private bool IsLoadingCenters = true;
    private string? ErrorMessage;
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Centers.AddRange(await CenterService.GetCentersAsync());
            Centers.AddRange(await CenterService.GetSwimmingPoolsAsync());
        }
        catch
        {
            ErrorMessage = "Centre kunne ikke hentes lige nu.";
        }
        finally
        {
            IsLoadingCenters = false;
        }
    }

    private void SelectCenter(Facility center)
    {
        Message = $"{center.Name} er valgt som dit center.";
    }
}