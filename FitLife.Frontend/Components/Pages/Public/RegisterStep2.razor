@page "/register-step2"
@rendermode InteractiveServer
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services

<div class="container-fluid px-0">

    <!-- Shared navbar for public pages -->
    <PublicNavbar />

    <section class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Opret medlemskab</h2>

            <!-- Prototype-knap -->
            <!-- TODO: Kan senere åbne support/chat/hjælpesektion -->
            <button class="btn btn-outline-secondary">
                Hjælp mig
            </button>
        </div>

        <!-- Step-indikator -->
        <div class="row mb-4 text-center">
            <div class="col">
                <div class="border rounded p-3 bg-light">
                    Trin 1<br />
                    Personlige informationer
                </div>
            </div>

            <div class="col">
                <div class="border rounded p-3 bg-success text-white">
                    Trin 2<br />
                    Vælg medlemskabstype
                </div>
            </div>

            <div class="col">
                <div class="border rounded p-3 bg-light">
                    Trin 3<br />
                    Betalingsoplysninger
                </div>
            </div>
        </div>

        <div class="row g-4">

            <!-- Valg af center og medlemskab -->
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-body p-4">

                        <h4 class="mb-3">Vælg center</h4>

                        <!-- Midlertidig dropdown med centre -->
                        <!-- TODO: Senere skal centre hentes fra FacilityService/backend -->
                        <select class="form-select mb-4"
                                @bind="SelectedCenterName">

                            <option value="">Vælg center</option>

                            @foreach (var center in Centers)
                            {
                                <option value="@center.Name">
                                    @center.Name
                                </option>
                            }
                        </select>

                        <h4 class="mb-3">Vælg medlemskabstype</h4>

                        <!-- Midlertidige medlemskabstyper -->
                        <!-- TODO: Skal senere enten mappes til backend enum eller hentes fra backend -->
                        <div class="list-group mb-4">

                            @foreach (var membershipType in MembershipTypes)
                            {
                                <button type="button"
                                        class="list-group-item list-group-item-action @(SelectedMembership == membershipType ? "active" : "")"
                                        @onclick="() => SelectMembership(membershipType)">

                                    <div class="d-flex justify-content-between">
                                        <span>@membershipType.Name medlemskab</span>

                                        <strong>
                                            @membershipType.MonthlyPrice kr./md.
                                        </strong>
                                    </div>

                                    <small>
                                        @membershipType.Description
                                    </small>

                                </button>
                            }
                        </div>

                        <h4 class="mb-3">Vælg tilvalg</h4>

                        <!-- TODO:
                             UserService backend har lige nu MembershipOptional som enum:
                             Swimming eller Pizza.
                             Personlig træning og digital træning findes ikke som backend-tilvalg endnu.
                             Derfor bruges disse kun som prototypevalg lige nu. -->
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   @bind="PersonalTrainingAddon" />

                            <label class="form-check-label">
                                Personlig træning +150 kr./md.
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   @bind="DigitalTrainingAddon" />

                            <label class="form-check-label">
                                Digital træning +50 kr./md.
                            </label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Message))
                        {
                            <div class="alert alert-warning mt-4">
                                @Message
                            </div>
                        }

                    </div>
                </div>
            </div>

            <!-- Oversigt over brugerens valg -->
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body p-4">

                        <h4>Dine valg</h4>

                        <p>
                            <strong>Center:</strong><br />
                            @(string.IsNullOrWhiteSpace(SelectedCenterName)
                                ? "Ikke valgt"
                                : SelectedCenterName)
                        </p>

                        <p>
                            <strong>Valgt medlemskabstype:</strong><br />
                            @(SelectedMembership is null
                                ? "Ikke valgt"
                                : SelectedMembership.Name)
                        </p>

                        <p>
                            <strong>Valgte tilvalg:</strong><br />

                            @if (!PersonalTrainingAddon && !DigitalTrainingAddon)
                            {
                                <span>Ingen tilvalg</span>
                            }
                            else
                            {
                                @if (PersonalTrainingAddon)
                                {
                                    <span>Personlig træning</span>
                                    <br />
                                }

                                @if (DigitalTrainingAddon)
                                {
                                    <span>Digital træning</span>
                                }
                            }
                        </p>

                        <hr />

                        <h5>Total pris pr. måned</h5>

                        <h3>@TotalPrice kr.</h3>

                    </div>
                </div>
            </div>

        </div>

        <div class="d-flex justify-content-between mt-4">
            <a href="/register-step1"
               class="btn btn-outline-secondary">
                Tilbage
            </a>

            <button class="btn btn-success px-4"
                    @onclick="GoToNextStep">
                Næste
            </button>
        </div>

    </section>

    <AppFooter />

</div>

@code {
    // Gemmer navnet på det valgte center.
    // TODO: Senere skal dette mappes til en rigtig Affiliation Guid fra FacilityService.
    private string SelectedCenterName = "";

    // Gemmer det valgte medlemskab i frontend.
    private MembershipType? SelectedMembership;

    // Prototype-tilvalg.
    // TODO: Disse skal senere afklares med backend-modellen.
    private bool PersonalTrainingAddon;

    private bool DigitalTrainingAddon;

    private string Message = "";

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [Inject]
    private RegistrationStateService RegistrationState { get; set; } = default!;

    // Midlertidig mock data til centre.
    // TODO: Skal senere hentes fra backend/API.
    private List<Center> Centers = new()
    {
        new Center
        {
            Name = "Aarhus C",
            City = "Aarhus",
            Address = "Eksempelvej 1"
        },

        new Center
        {
            Name = "Randers",
            City = "Randers",
            Address = "Eksempelvej 2"
        },

        new Center
        {
            Name = "Silkeborg",
            City = "Silkeborg",
            Address = "Eksempelvej 3"
        },

        new Center
        {
            Name = "Horsens",
            City = "Horsens",
            Address = "Eksempelvej 4"
        },

        new Center
        {
            Name = "Vejle",
            City = "Vejle",
            Address = "Eksempelvej 5"
        },

        new Center
        {
            Name = "Skanderborg",
            City = "Skanderborg",
            Address = "Eksempelvej 6"
        }
    };

    // Midlertidig mock data til medlemskabstyper.
    // OBS:
    // Din backend enum har kun Standard og Premium.
    // Derfor bør vi senere enten ændre "Basis/Plus/Premium"
    // eller mappe dem korrekt til backend.
    private List<MembershipType> MembershipTypes = new()
    {
        new MembershipType
        {
            Name = "Standard",
            Description = "Adgang til center og basis træningsfaciliteter.",
            MonthlyPrice = 199
        },

        new MembershipType
        {
            Name = "Premium",
            Description = "Adgang til center, holdtræning og digitale træningsprogrammer.",
            MonthlyPrice = 299
        }
    };

    protected override void OnInitialized()
    {
        // Henter tidligere registreringsdata fra shared state.
        SelectedCenterName = RegistrationState.SelectedCenterName;

        SelectedMembership = RegistrationState.SelectedMembership;

        PersonalTrainingAddon = RegistrationState.PersonalTrainingAddon;

        DigitalTrainingAddon = RegistrationState.DigitalTrainingAddon;
    }

    private decimal TotalPrice =>
        (SelectedMembership?.MonthlyPrice ?? 0) +
        (PersonalTrainingAddon ? 150 : 0) +
        (DigitalTrainingAddon ? 50 : 0);

    private void SelectMembership(MembershipType membershipType)
    {
        SelectedMembership = membershipType;
        Message = "";
    }

    private void GoToNextStep()
    {
        if (string.IsNullOrWhiteSpace(SelectedCenterName))
        {
            Message = "Vælg et center.";
            return;
        }

        if (SelectedMembership is null)
        {
            Message = "Vælg en medlemskabstype.";
            return;
        }

        // Gemmer registreringsdata i shared registration state,
        // så step 3 kan bruge brugerens valg.
        RegistrationState.SelectedCenterName = SelectedCenterName;

        RegistrationState.SelectedMembership = SelectedMembership;

        RegistrationState.PersonalTrainingAddon = PersonalTrainingAddon;

        RegistrationState.DigitalTrainingAddon = DigitalTrainingAddon;

        Navigation.NavigateTo("/register-step3");
    }
}