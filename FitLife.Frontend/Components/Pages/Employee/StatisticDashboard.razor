@page "/employee/statistics"
@rendermode InteractiveServer
@layout EmployeeLayout
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject StatisticService StatisticService

<div class="container-fluid px-0">

    <EmployeeNavbar />

    <section class="container py-5">

        <div class="mb-5">
            <div class="col-md-7">
                <span class="badge bg-dark mb-3 px-3 py-2">
                    STATISTIK
                </span>
                <h1 class="fw-bold mb-3">
                    Statistik dashboard
                </h1>
                <p class="lead text-muted">
                    Se fremmøde, tilmeldte og venteliste for alle hold og sessioner.
                </p>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="alert alert-info">Henter statistikker...</div>
        }
        else if (Statistics.Count == 0)
        {
            <div class="alert alert-secondary">Ingen statistikker at vise.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var stat in Statistics)
                {
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">

                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5 class="fw-bold mb-0">@stat.Name</h5>
                                    <span class="badge @(stat.ActiveClass ? "bg-success" : "bg-secondary")">
                                        @(stat.ActiveClass ? "Aktiv" : "Inaktiv")
                                    </span>
                                </div>

                                <p class="text-muted mb-3">@stat.Description</p>

                                <div class="row text-center g-2 mb-3">
                                    <div class="col-4">
                                        <div class="border rounded p-2">
                                            <div class="fw-bold fs-4">@stat.Registrered.Count</div>
                                            <small class="text-muted">Tilmeldte</small>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="border rounded p-2">
                                            <div class="fw-bold fs-4">@stat.Attended.Count</div>
                                            <small class="text-muted">Fremmødt</small>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="border rounded p-2">
                                            <div class="fw-bold fs-4">@stat.WaitingList.Count</div>
                                            <small class="text-muted">Venteliste</small>
                                        </div>
                                    </div>
                                </div>

                                <button class="btn btn-outline-dark btn-sm"
                                        @onclick="() => ToggleDetails(stat.Id)">
                                    @(ExpandedId == stat.Id ? "Skjul detaljer" : "Vis detaljer")
                                </button>

                                @if (ExpandedId == stat.Id)
                                {
                                    <div class="mt-3">
                                        <p class="mb-1"><strong>Oprettet:</strong> @stat.DataCreated.ToString("dd/MM/yyyy")</p>
                                        <p class="mb-1"><strong>Sidst opdateret:</strong> @stat.DateModified.ToString("dd/MM/yyyy")</p>
                                        <p class="mb-1"><strong>Facilitet ID:</strong> @stat.FacilityId</p>
                                        <p class="mb-0"><strong>Lokale ID:</strong> @stat.RoomId</p>
                                    </div>
                                }

                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-info mt-4">@StatusMessage</div>
        }

    </section>

    <AppFooter />

</div>

@code {

    private List<Statistic> Statistics = new();
    private bool IsLoading = true;
    private string StatusMessage = "";
    private Guid? ExpandedId = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IsLoading = true;
            Statistics = await StatisticService.GetAllAsync();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Kunne ikke hente statistikker: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    // Toggles detail view for a statistic
    private void ToggleDetails(Guid id)
    {
        ExpandedId = ExpandedId == id ? null : id;
    }
}