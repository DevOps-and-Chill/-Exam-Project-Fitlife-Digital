@page "/create-session"
@rendermode InteractiveServer
@using FitLife.Frontend.Models

<div class="container-fluid px-0">

    <EmployeeNavbar />

    <section class="container py-5">

        <div class="mb-4">
            <h1 class="fw-bold">Opret hold</h1>
            <p class="lead">Opret et nyt hold i centerets holdplan.</p>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Holdtype</label>
                        <input class="form-control"
                               @bind="NewSession.Title"
                               placeholder="Fx Yoga, Spinning, Crossfit" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Instruktør</label>
                        <input class="form-control"
                               @bind="NewSession.InstructorName"
                               placeholder="Navn på instruktør" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Beskrivelse af træning</label>
                        <textarea class="form-control"
                                  rows="4"
                                  @bind="NewSession.Description"></textarea>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Dato</label>
                        <input class="form-control"
                               type="date"
                               @bind="SelectedDate" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Klokkeslæt</label>
                        <input class="form-control"
                               type="time"
                               @bind="SelectedTime" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Samlet antal pladser</label>
                        <input class="form-control"
                               type="number"
                               @bind="NewSession.Capacity" />
                    </div>

                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="alert alert-info mt-4">
                        @Message
                    </div>
                }

                <div class="d-flex gap-3 mt-4">
                    <button class="btn btn-success px-4" @onclick="Save">
                        Gem
                    </button>

                    <button class="btn btn-outline-success px-4" @onclick="SaveAndCreateMore">
                        Gem og opret flere hold
                    </button>

                    <a href="/employee-dashboard" class="btn btn-outline-secondary px-4">
                        Afbryd
                    </a>
                </div>

            </div>
        </div>

    </section>

    <AppFooter />

</div>

@code {
    private TrainingSession NewSession = new()
    {
        Capacity = 10,
        RegisteredCount = 0
    };

    private DateTime? SelectedDate;
    private TimeOnly? SelectedTime;
    private string Message = "";

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private bool Validate()
    {
        if (string.IsNullOrWhiteSpace(NewSession.Title) ||
            string.IsNullOrWhiteSpace(NewSession.InstructorName) ||
            SelectedDate is null ||
            SelectedTime is null ||
            NewSession.Capacity <= 0)
        {
            Message = "Udfyld holdtype, instruktør, dato, klokkeslæt og antal pladser.";
            return false;
        }

        return true;
    }

    private void SetStartTime()
    {
        if (SelectedDate is not null && SelectedTime is not null)
        {
            NewSession.StartTime = SelectedDate.Value.Date + SelectedTime.Value.ToTimeSpan();
        }
    }

    private void Save()
    {
        if (!Validate())
            return;

        SetStartTime();

        Message = $"Holdet {NewSession.Title} er oprettet.";

        Navigation.NavigateTo("/manage-sessions");
    }

    private void SaveAndCreateMore()
    {
        if (!Validate())
            return;

        SetStartTime();

        Message = $"Holdet {NewSession.Title} er oprettet. Du kan nu oprette et nyt hold.";

        NewSession = new TrainingSession
        {
            Capacity = 10,
            RegisteredCount = 0
        };

        SelectedDate = null;
        SelectedTime = null;
    }
}