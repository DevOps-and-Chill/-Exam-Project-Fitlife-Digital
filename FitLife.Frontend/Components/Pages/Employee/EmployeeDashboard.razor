@page "/employee-dashboard"
@rendermode InteractiveServer

<div class="container-fluid px-0">

    <EmployeeNavbar />

    <section class="container py-5">

        <div class="mb-5">
            <span class="badge bg-dark mb-3 px-3 py-2">
                ANSAT OMRÅDE
            </span>

            <h1 class="fw-bold">
                Ansat dashboard
            </h1>

            <p class="lead text-muted">
                Administrer hold, medlemmer, centre og personlig træning fra ét samlet overblik.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">

                        <div class="fs-2 mb-3">
                            📅
                        </div>

                        <h3 class="fw-bold">
                            Holdtræning
                        </h3>

                        <p class="text-muted">
                            Administrer eksisterende hold, rediger kapacitet eller opret nye hold i holdplanen.
                        </p>

                        <div class="d-grid gap-2">
                            <a href="/manage-sessions"
                               class="btn btn-success">
                                Administrer hold
                            </a>

                            <a href="/create-session"
                               class="btn btn-outline-success">
                                + Opret hold
                            </a>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">

                        <div class="fs-2 mb-3">
                            👥
                        </div>

                        <h3 class="fw-bold">
                            Medlemmer
                        </h3>

                        <p class="text-muted">
                            Søg efter medlemmer, rediger medlemsoplysninger eller opret nye medlemmer via receptionen.
                        </p>

                        <div class="d-grid gap-2">
                            <a href="/manage-members"
                               class="btn btn-success">
                                Administrer medlemmer
                            </a>

                            <a href="/create-member"
                               class="btn btn-outline-success">
                                + Opret medlem
                            </a>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">

                        <div class="fs-2 mb-3">
                            💪
                        </div>

                        <h3 class="fw-bold">
                            Personlig træning
                        </h3>

                        <p class="text-muted">
                            Se planlagte sessioner og håndter ønsker om personlig træning fra medlemmer.
                        </p>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success"
                                    @onclick="ShowPTSessions">
                                Se mine sessioner
                            </button>

                            <button class="btn btn-outline-success"
                                    @onclick="ShowPTRequests">
                                Ønsker om sessioner
                            </button>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body p-4">

                        <div class="fs-2 mb-3">
                            🏢
                        </div>

                        <h3 class="fw-bold">
                            Centre
                        </h3>

                        <p class="text-muted">
                            Administrer centeroplysninger og opret afvigelser for åbningstider eller drift.
                        </p>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success"
                                    @onclick="ShowCenters">
                                Administrer center
                            </button>

                            <button class="btn btn-outline-success"
                                    @onclick="ShowCenterDeviation">
                                Opret afvigelse for center
                            </button>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-info mt-4">
                @Message
            </div>
        }

    </section>

    <AppFooter />

</div>

@code {
    private string Message = "";

    private void ShowPTSessions()
    {
        Message = "Visning af personlige træningssessioner er ikke implementeret endnu.";
    }

    private void ShowPTRequests()
    {
        Message = "Visning af ønsker om sessioner er ikke implementeret endnu.";
    }

    private void ShowCenters()
    {
        Message = "Centeradministration er ikke implementeret endnu.";
    }

    private void ShowCenterDeviation()
    {
        Message = "Oprettelse af centerafvigelse er ikke implementeret endnu.";
    }
}