@page "/create-member"
@rendermode InteractiveServer
@using FitLife.Frontend.Models

<div class="container-fluid px-0">

    <!-- Shared navigation for employee/admin pages -->
    <EmployeeNavbar />

    <section class="container py-5">

        <h1 class="fw-bold mb-3">Opret medlem</h1>
        <p class="lead">
            Opret et nyt medlem via receptionen.
        </p>

        <!-- Prototype/UX note: viser medarbejderen en vigtig arbejdsgang fra casen -->
        <div class="alert alert-info">
            Husk at informere kunden om, at de bliver bedt om at lave password ved første login.
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">

                <!-- Formularen binder direkte til NewMember-modellen.
                     Senere kan NewMember sendes videre til backend via MemberService/API. -->
                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Fornavn</label>
                        <input class="form-control" @bind="NewMember.FirstName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Efternavn</label>
                        <input class="form-control" @bind="NewMember.LastName" />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Adresse</label>
                        <input class="form-control" @bind="NewMember.Address" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Postnr.</label>
                        <input class="form-control" @bind="NewMember.PostalCode" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">By</label>
                        <input class="form-control" @bind="NewMember.City" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Fødselsdag</label>
                        <input class="form-control" type="date" @bind="NewMember.BirthDate" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">E-mailadresse</label>
                        <input class="form-control" type="email" @bind="NewMember.Email" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Telefonnummer</label>
                        <input class="form-control" @bind="NewMember.PhoneNumber" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Center</label>

                        <!-- Mock-data fra Centers-listen.
                             Senere bør listen hentes fra CenterService/API. -->
                        <select class="form-select" @bind="SelectedCenterName">
                            <option value="">Vælg center</option>
                            @foreach (var center in Centers)
                            {
                                <option value="@center.Name">@center.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Medlemskabstype</label>

                        <!-- Mock-data fra MembershipTypes-listen.
                             Senere bør medlemskabstyper/priser hentes fra backend. -->
                        <select class="form-select" @bind="NewMember.MembershipType">
                            <option value="">Vælg medlemskabstype</option>
                            @foreach (var membershipType in MembershipTypes)
                            {
                                <option value="@membershipType.Name">
                                    @membershipType.Name - @membershipType.MonthlyPrice kr./md.
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Betalingsform</label>

                        <!-- PaymentInfo bruges kun som frontend/UI-model lige nu.
                             Senere bør betaling håndteres via betalingsservice eller betalingsudbyder. -->
                        <select class="form-select" @bind="Payment.PaymentMethod">
                            <option value="">Vælg betalingsform</option>
                            <option>Dankort - kunden scanner kort på terminalen</option>
                            <option>MobilePay - kunden scanner QR</option>
                            <option>Faktura - kunden modtager faktura på mail</option>
                        </select>
                    </div>

                </div>

                <!-- Midlertidig UI-feedback.
                     Senere kan denne besked komme fra MemberService/API response. -->
                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="alert alert-info mt-4">
                        @Message
                    </div>
                }

                <div class="d-flex gap-3 mt-4">
                    <button class="btn btn-success px-4" @onclick="CreateNewMember">
                        Opret medlem
                    </button>

                    <a href="/manage-members" class="btn btn-outline-secondary px-4">
                        Afbryd
                    </a>
                </div>

            </div>
        </div>

    </section>

    <AppFooter />

</div>

@code {
    // NewMember samler alle medlemsoplysninger fra formularen.
    // Senere kan dette objekt sendes til MemberService.CreateMemberAsync().
    private Member NewMember = new()
    {
        BirthDate = DateTime.Today,
        MemberSince = DateTime.Today,
        PaymentStatus = "Betalt"
    };

    // PaymentInfo holder betalingsvalg adskilt fra Member.
    // Det er vigtigt, fordi betaling senere typisk håndteres af en separat betalingsservice.
    private PaymentInfo Payment = new();

    private string SelectedCenterName = "";
    private string Message = "";

    // Mock-data til prototype.
    // TODO: Erstat med CenterService.GetCentersAsync(), når backend/microservice er klar.
    private List<Center> Centers = new()
    {
        new Center
        {
            Name = "Aarhus C",
            City = "Aarhus",
            Address = "Eksempelvej 1"
        },
        new Center
        {
            Name = "Randers",
            City = "Randers",
            Address = "Eksempelvej 2"
        },
        new Center
        {
            Name = "Silkeborg",
            City = "Silkeborg",
            Address = "Eksempelvej 3"
        },
        new Center
        {
            Name = "Horsens",
            City = "Horsens",
            Address = "Eksempelvej 4"
        },
        new Center
        {
            Name = "Vejle",
            City = "Vejle",
            Address = "Eksempelvej 5"
        },
        new Center
        {
            Name = "Skanderborg",
            City = "Skanderborg",
            Address = "Eksempelvej 6"
        }
    };

    // Mock-data til prototype.
    // TODO: Erstat med MembershipService/API, så priser og typer ikke ligger hardcoded i UI.
    private List<MembershipType> MembershipTypes = new()
    {
        new MembershipType
        {
            Name = "Basis",
            Description = "Adgang til center og basis træningsfaciliteter.",
            MonthlyPrice = 199
        },
        new MembershipType
        {
            Name = "Plus",
            Description = "Adgang til center, holdtræning og digitale træningsprogrammer.",
            MonthlyPrice = 299
        },
        new MembershipType
        {
            Name = "Premium",
            Description = "Adgang til alle faciliteter, hold og ekstra personlig træning.",
            MonthlyPrice = 399
        }
    };

    private void CreateNewMember()
    {
        // Simpel frontend-validering.
        // Senere bør backend også validere data, før medlemmet gemmes i databasen.
        if (string.IsNullOrWhiteSpace(NewMember.FirstName) ||
            string.IsNullOrWhiteSpace(NewMember.LastName) ||
            string.IsNullOrWhiteSpace(NewMember.Email) ||
            string.IsNullOrWhiteSpace(SelectedCenterName) ||
            string.IsNullOrWhiteSpace(NewMember.MembershipType) ||
            string.IsNullOrWhiteSpace(Payment.PaymentMethod))
        {
            Message = "Udfyld fornavn, efternavn, email, center, medlemskabstype og betalingsform.";
            return;
        }

        // Midlertidig prototype-handling.
        // TODO: Erstat med kald til MemberService/CreateMember API.
        Message = $"Medlemmet {NewMember.FirstName} {NewMember.LastName} er oprettet.";

        // Nulstiller formularen efter oprettelse.
        NewMember = new Member
        {
            BirthDate = DateTime.Today,
            MemberSince = DateTime.Today,
            PaymentStatus = "Betalt"
        };

        Payment = new PaymentInfo();
        SelectedCenterName = "";
    }
}