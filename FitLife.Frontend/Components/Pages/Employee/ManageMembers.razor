@page "/manage-members"
@rendermode InteractiveServer
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject MemberService MemberService

<div class="container-fluid px-0">

    <!-- Shared navbar for medarbejder/admin sider -->
    <EmployeeNavbar />

    <section class="container py-5">

        <!-- Side-header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold">Administrer medlemmer</h1>
                <p class="lead">Søg, se og rediger medlemmer.</p>
            </div>

            <!-- Navigerer til oprettelse af nyt medlem -->
            <a href="/create-member" class="btn btn-success">
                OPRET MEDLEM
            </a>
        </div>

        <!-- Søgefelt -->
        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="row g-3 align-items-end">

                    <div class="col-md-8">

                        <label class="form-label">
                            Søg efter medlem
                        </label>

                        <!-- Søger dynamisk mens brugeren skriver -->
                        <input class="form-control"
                               placeholder="Søg efter medlem..."
                               @bind="SearchText"
                               @bind:event="oninput" />
                    </div>

                    <div class="col-md-4">

                        <!-- Nulstiller søgning -->
                        <button class="btn btn-outline-secondary w-100"
                                @onclick="ClearSearch">
                            Vis alle
                        </button>

                    </div>
                </div>
            </div>
        </div>

        @if (IsLoading)
        {
            <!-- Vises mens frontend venter på svar fra UserService API -->
            <div class="alert alert-info">
                Henter medlemmer...
            </div>
        }
        else
        {
            <div class="row g-4">

                <!-- Venstre side:
                     Liste over medlemmer -->
                <div class="col-md-6">

                    <!-- Loop gennem filtrerede medlemmer -->
                    @foreach (var member in FilteredMembers)
                    {
                        <div class="card shadow-sm mb-3">
                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-center">

                                    <!-- Medlemsinformation -->
                                    <div>

                                        <!-- Ubiquitous language:
                                             Frontend bruger nu samme navne som UserService -->
                                        <h5>
                                            @member.GivenName @member.FamilyName
                                        </h5>

                                        <!-- Alder beregnes ud fra BirthDate -->
                                        <p class="mb-1">
                                            Alder: @member.Age
                                        </p>

                                        <!-- MembershipType kommer direkte fra UserService -->
                                        <p class="mb-1">
                                            Medlemskabstype: @member.MembershipType
                                        </p>

                                        <!-- ActiveMembership bruges nu i stedet for PaymentStatus -->
                                        <p class="mb-1">
                                            Medlemskab aktivt:
                                            @(member.ActiveMembership ? "Ja" : "Nej")
                                        </p>

                                        <!-- StartDate kommer fra backend/UserService -->
                                        <p class="text-muted mb-0">
                                            Medlem siden:
                                            @member.StartDate.ToString("dd/MM/yyyy")
                                        </p>

                                    </div>

                                    <!-- Vælger medlem til redigering -->
                                    <button class="btn btn-outline-dark"
                                            @onclick="() => SelectMember(member)">
                                        Rediger
                                    </button>

                                </div>

                            </div>
                        </div>
                    }
                </div>

                <!-- Højre side:
                     Redigeringspanel -->
                <div class="col-md-6">

                    @if (SelectedMember is null)
                    {
                        <!-- Vises hvis intet medlem er valgt -->
                        <div class="card shadow-sm">
                            <div class="card-body p-4 text-muted">
                                Vælg et medlem for at redigere oplysninger.
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Redigeringsformular -->
                        <div class="card shadow-sm">
                            <div class="card-body p-4">

                                <h4>
                                    Rediger medlem
                                </h4>

                                <div class="row g-3">

                                    <!-- Alle inputs er bundet direkte til SelectedMember -->
                                    <!-- Ændringer sker derfor live i objektet -->

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Fornavn
                                        </label>

                                        <!-- GivenName matcher UserService -->
                                        <input class="form-control"
                                               @bind="SelectedMember.GivenName" />
                                    </div>

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Efternavn
                                        </label>

                                        <!-- FamilyName matcher UserService -->
                                        <input class="form-control"
                                               @bind="SelectedMember.FamilyName" />
                                    </div>

                                    <div class="col-md-12">

                                        <label class="form-label">
                                            Adresse
                                        </label>

                                        <input class="form-control"
                                               @bind="SelectedMember.Address" />
                                    </div>

                                    <!-- PostalCode og City findes ikke i UserService endnu -->
                                    <!-- TODO:
                                         Tilføj til UserService hvis disse felter ønskes senere -->

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            E-mailadresse
                                        </label>

                                        <input class="form-control"
                                               type="email"
                                               @bind="SelectedMember.Email" />
                                    </div>

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Telefonnummer
                                        </label>

                                        <!-- Telephone matcher UserService -->
                                        <input class="form-control"
                                               @bind="SelectedMember.Telephone" />
                                    </div>

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Fødselsdag
                                        </label>

                                        <!-- BirthDate bruges til beregning af Age -->
                                        <input class="form-control"
                                               type="date"
                                               @bind="SelectedMember.BirthDate" />
                                    </div>

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Medlemskabstype
                                        </label>

                                        <!-- TODO:
                                             Senere kan medlemskabstyper
                                             hentes dynamisk fra backend/API -->
                                        <select class="form-select"
                                                @bind="SelectedMember.MembershipType">

                                            <option>Standard</option>
                                            <option>Premium</option>
                                            <option>Basis</option>
                                            <option>Plus</option>

                                        </select>
                                    </div>

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Aktivt medlemskab
                                        </label>

                                        <!-- ActiveMembership bruges nu i stedet for PaymentStatus -->
                                        <select class="form-select"
                                                @bind="SelectedMember.ActiveMembership">

                                            <option value="true">Ja</option>
                                            <option value="false">Nej</option>

                                        </select>
                                    </div>

                                    <!-- CurrentPersonalTrainer findes ikke i UserService endnu -->
                                    <!-- TODO:
                                         Skal senere kobles til TrainerService -->

                                </div>

                                <div class="d-grid gap-2 mt-4">

                                    <!-- Gemmer ændringer -->
                                    <!-- TODO:
                                         Skal senere sende ændringer til backend via MemberService.
                                         UserService har endpointet POST /member/UpsertMember. -->
                                    <button class="btn btn-success"
                                            @onclick="SaveChanges">
                                        Gem ændringer
                                    </button>

                                    <!-- Prototypefunktion -->
                                    <!-- TODO:
                                         Skal senere åbne betalingsflow -->
                                    <button class="btn btn-outline-warning"
                                            @onclick="UpdatePaymentMethod">
                                        Opdater betalingsmiddel
                                    </button>

                                    <!-- Lukker redigering -->
                                    <button class="btn btn-outline-secondary"
                                            @onclick="ClearSelection">
                                        Afbryd
                                    </button>

                                </div>

                            </div>
                        </div>
                    }
                </div>

            </div>
        }

        <!-- Midlertidig statusbesked -->
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-info mt-4">
                @Message
            </div>
        }

    </section>

    <AppFooter />

</div>

@code {

    // Tekst brugt til søgning
    private string SearchText = "";

    // Midlertidig feedback til UI
    private string Message = "";

    // Bruges til at vise loading-state mens API'et henter medlemmer
    private bool IsLoading = true;

    // Det medlem medarbejderen aktuelt redigerer
    private Member? SelectedMember;

    // Listen fyldes nu via UserService API i stedet for lokal mock-data
    private List<Member> Members = new();

    // Kører automatisk når siden loader.
    // Henter medlemmer fra UserService via MemberService.
    protected override async Task OnInitializedAsync()
    {
        try
        {
            Members = await MemberService.GetMembersAsync();
        }
        catch
        {
            Message = "Medlemmer kunne ikke hentes fra UserService API.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    // Filtrerer medlemmer ud fra søgetekst
    private IEnumerable<Member> FilteredMembers =>
        Members.Where(m =>

            string.IsNullOrWhiteSpace(SearchText) ||

            m.GivenName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||

            m.FamilyName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||

            m.Email.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||

            m.MembershipType.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

    // Vælger medlem til redigering
    private void SelectMember(Member member)
    {
        SelectedMember = member;
        Message = "";
    }

    // Gemmer ændringer
    // TODO:
    // Skal senere sende ændringer til backend via API/service
    private void SaveChanges()
    {
        if (SelectedMember is null)
            return;

        Message = MemberService.SaveMember(SelectedMember);
    }

    // Prototypefunktion til betalingsopdatering
    // TODO:
    // Skal senere integreres med betalingsservice
    private void UpdatePaymentMethod()
    {
        if (SelectedMember is null)
            return;

        Message = MemberService.UpdatePaymentMethod(SelectedMember);
    }

    // Lukker redigeringspanel
    private void ClearSelection()
    {
        SelectedMember = null;
        Message = "";
    }

    // Nulstiller søgning
    private void ClearSearch()
    {
        SearchText = "";
    }
}