@page "/manage-members"
@rendermode InteractiveServer
@using FitLife.Frontend.Models

<div class="container-fluid px-0">

    <!-- Shared navbar for medarbejder/admin sider -->
    <EmployeeNavbar />

    <section class="container py-5">

        <!-- Side-header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold">Administrer medlemmer</h1>
                <p class="lead">Søg, se og rediger medlemmer.</p>
            </div>

            <!-- Navigerer til oprettelse af nyt medlem -->
            <a href="/create-member" class="btn btn-success">
                OPRET MEDLEM
            </a>
        </div>

        <!-- Søgefelt -->
        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="row g-3 align-items-end">

                    <div class="col-md-8">

                        <label class="form-label">
                            Søg efter medlem
                        </label>

                        <!-- Søger dynamisk mens brugeren skriver -->
                        <input class="form-control"
                               placeholder="Søg efter medlem..."
                               @bind="SearchText"
                               @bind:event="oninput" />
                    </div>

                    <div class="col-md-4">

                        <!-- Nulstiller søgning -->
                        <button class="btn btn-outline-secondary w-100"
                                @onclick="ClearSearch">
                            Vis alle
                        </button>

                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <!-- Venstre side:
                 Liste over medlemmer -->
            <div class="col-md-6">

                <!-- Loop gennem filtrerede medlemmer -->
                @foreach (var member in FilteredMembers)
                {
                    <div class="card shadow-sm mb-3">
                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-center">

                                <!-- Medlemsinformation -->
                                <div>

                                    <h5>
                                        @member.FirstName @member.LastName
                                    </h5>

                                    <p class="mb-1">
                                        Alder: @member.Age
                                    </p>

                                    <p class="mb-1">
                                        Medlemskabstype: @member.MembershipType
                                    </p>

                                    <p class="mb-1">
                                        Betalingsstatus: @member.PaymentStatus
                                    </p>

                                    <p class="text-muted mb-0">
                                        Medlem siden:
                                        @member.MemberSince.ToString("dd/MM/yyyy")
                                    </p>

                                </div>

                                <!-- Vælger medlem til redigering -->
                                <button class="btn btn-outline-dark"
                                        @onclick="() => SelectMember(member)">
                                    Rediger
                                </button>

                            </div>

                        </div>
                    </div>
                }
            </div>

            <!-- Højre side:
                 Redigeringspanel -->
            <div class="col-md-6">

                @if (SelectedMember is null)
                {
                    <!-- Vises hvis intet medlem er valgt -->
                    <div class="card shadow-sm">
                        <div class="card-body p-4 text-muted">
                            Vælg et medlem for at redigere oplysninger.
                        </div>
                    </div>
                }
                else
                {
                    <!-- Redigeringsformular -->
                    <div class="card shadow-sm">
                        <div class="card-body p-4">

                            <h4>
                                Rediger medlem
                            </h4>

                            <div class="row g-3">

                                <!-- Alle inputs er bundet direkte til SelectedMember -->
                                <!-- Ændringer sker derfor live i objektet -->

                                <div class="col-md-6">
                                    <label class="form-label">Fornavn</label>
                                    <input class="form-control"
                                           @bind="SelectedMember.FirstName" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Efternavn</label>
                                    <input class="form-control"
                                           @bind="SelectedMember.LastName" />
                                </div>

                                <div class="col-md-8">
                                    <label class="form-label">Adresse</label>
                                    <input class="form-control"
                                           @bind="SelectedMember.Address" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Postnr.</label>
                                    <input class="form-control"
                                           @bind="SelectedMember.PostalCode" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">By</label>
                                    <input class="form-control"
                                           @bind="SelectedMember.City" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">E-mailadresse</label>
                                    <input class="form-control"
                                           type="email"
                                           @bind="SelectedMember.Email" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Telefonnummer</label>
                                    <input class="form-control"
                                           @bind="SelectedMember.PhoneNumber" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Fødselsdag</label>
                                    <input class="form-control"
                                           type="date"
                                           @bind="SelectedMember.BirthDate" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Medlemskabstype</label>

                                    <!-- TODO:
                                         Senere kan medlemskabstyper
                                         hentes fra backend/API -->
                                    <select class="form-select"
                                            @bind="SelectedMember.MembershipType">

                                        <option>Basis</option>
                                        <option>Plus</option>
                                        <option>Premium</option>

                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Betalingsstatus</label>

                                    <!-- TODO:
                                         Senere kobles betalingsstatus
                                         sandsynligvis til betalingsservice -->
                                    <select class="form-select"
                                            @bind="SelectedMember.PaymentStatus">

                                        <option>Betalt</option>
                                        <option>Mangler betaling</option>
                                        <option>Faktura sendt</option>

                                    </select>
                                </div>

                                <div class="col-md-12">
                                    <label class="form-label">
                                        Nuværende PT
                                    </label>

                                    <input class="form-control"
                                           @bind="SelectedMember.CurrentPersonalTrainer" />
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-4">

                                <!-- Gemmer ændringer -->
                                <!-- TODO:
                                     Skal senere sende PUT/PATCH request til backend -->
                                <button class="btn btn-success"
                                        @onclick="SaveChanges">
                                    Gem ændringer
                                </button>

                                <!-- Prototypefunktion -->
                                <!-- TODO:
                                     Skal senere åbne betalingsflow -->
                                <button class="btn btn-outline-warning"
                                        @onclick="UpdatePaymentMethod">
                                    Opdater betalingsmiddel
                                </button>

                                <!-- Lukker redigering -->
                                <button class="btn btn-outline-secondary"
                                        @onclick="ClearSelection">
                                    Afbryd
                                </button>

                            </div>

                        </div>
                    </div>
                }
            </div>

        </div>

        <!-- Midlertidig statusbesked -->
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-info mt-4">
                @Message
            </div>
        }

    </section>

    <AppFooter />

</div>

@code {

    // Tekst brugt til søgning
    private string SearchText = "";

    // Midlertidig feedback til UI
    private string Message = "";

    // Det medlem medarbejderen aktuelt redigerer
    private Member? SelectedMember;

    // Midlertidig mock data til prototype
    // TODO:
    // Skal senere erstattes af data fra backend/API
    private List<Member> Members = new()
    {
        new Member
        {
            FirstName = "Jonas",
            LastName = "Madsen",
            Address = "Munkeallé 27",
            PostalCode = "8000",
            City = "Aarhus",
            Email = "jonas@example.com",
            PhoneNumber = "12345678",
            BirthDate = new DateTime(1999, 4, 12),
            MembershipType = "Plus",
            PaymentStatus = "Betalt",
            MemberSince = DateTime.Today.AddMonths(-6),
            CurrentPersonalTrainer = "Frederikke"
        },

        new Member
        {
            FirstName = "Frederik",
            LastName = "Nielsen",
            Address = "Vestergade 10",
            PostalCode = "8600",
            City = "Silkeborg",
            Email = "frederik@example.com",
            PhoneNumber = "22334455",
            BirthDate = new DateTime(1988, 9, 2),
            MembershipType = "Basis",
            PaymentStatus = "Mangler betaling",
            MemberSince = DateTime.Today.AddYears(-1),
            CurrentPersonalTrainer = ""
        },

        new Member
        {
            FirstName = "Charlotte",
            LastName = "Hansen",
            Address = "Stationsvej 4",
            PostalCode = "8700",
            City = "Horsens",
            Email = "charlotte@example.com",
            PhoneNumber = "87654321",
            BirthDate = new DateTime(1974, 1, 20),
            MembershipType = "Premium",
            PaymentStatus = "Betalt",
            MemberSince = DateTime.Today.AddYears(-3),
            CurrentPersonalTrainer = "Mikkel"
        }
    };

    // Filtrerer medlemmer ud fra søgetekst
    private IEnumerable<Member> FilteredMembers =>
        Members.Where(m =>

            string.IsNullOrWhiteSpace(SearchText) ||

            m.FirstName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||

            m.LastName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||

            m.Email.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||

            m.MembershipType.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

    // Vælger medlem til redigering
    private void SelectMember(Member member)
    {
        SelectedMember = member;
        Message = "";
    }

    // Gemmer ændringer
    // TODO:
    // Skal senere sende ændringer til backend via API/service
    private void SaveChanges()
    {
        if (SelectedMember is null)
            return;

        Message = $"Ændringer for {SelectedMember.FirstName} {SelectedMember.LastName} er gemt.";
    }

    // Prototypefunktion til betalingsopdatering
    // TODO:
    // Skal senere integreres med betalingsservice
    private void UpdatePaymentMethod()
    {
        if (SelectedMember is null)
            return;

        Message = $"Betalingsmiddel for {SelectedMember.FirstName} {SelectedMember.LastName} kan opdateres senere via betalingsintegration.";
    }

    // Lukker redigeringspanel
    private void ClearSelection()
    {
        SelectedMember = null;
        Message = "";
    }

    // Nulstiller søgning
    private void ClearSearch()
    {
        SearchText = "";
    }
}