@page "/inbox"
@using FitLife.Frontend.Models.DTOs
@using FitLife.Frontend.Services
@inject CurrentUserService CurrentUserService
@inject MessageService MessageService

<h3>Inbox</h3>

@if (messages.Count == 0)
{
    <p>Ingen beskeder.</p>
}
else
{


    <ul style="list-style: none; padding: 0;">
        @foreach (var message in messages)
        {
            <li style="border: 1px solid #ddd; padding: 12px; margin-bottom: 8px; border-radius: 6px; background: @(message.IsRead ? "#fff" : "#f0f7ff")">
                <div style="display: flex; justify-content: space-between;">
                    <strong>@message.Subject</strong>
                    <small>@message.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <p style="margin: 4px 0;">@message.Content</p>
                @if (!message.IsRead)
                {
                    <button @onclick="() => MarkAsRead(message.Id)">Marker som læst</button>
                }
            </li>
        }
    </ul>
}

@code {
    private List<MessageDto> messages;
    
    
    protected override async Task OnInitializedAsync()
    {
        var userId = CurrentUserService.CurrentUser?.GetId();

        if (userId is not null)
        {
            messages = await MessageService.GetMessagesByReceiverAsync(userId);
        }
    }

    private async Task MarkAsRead(string id)
    {
        await MessageService.MarkAsReadAsync(id);
        var message = messages.FirstOrDefault(m => m?.Id == id);
        if (message != null) message.IsRead = true;
    }
    

}
