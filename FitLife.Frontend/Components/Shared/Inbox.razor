@page "/inbox"
@using FitLife.Frontend.Models.DTOs
@inject FitLife.Frontend.Services.MessageService MessageService

<h3>Inbox</h3>


@if (messages.Any())
{
    <ul style="list-style: none; padding: 0;">
        @foreach (var message in messages)
        {
            <li style="border: 1px solid #ddd; padding: 12px; margin-bottom: 8px; border-radius: 6px; background: @(message.IsRead ? "#fff" : "#f0f7ff")">
                <div style="display: flex; justify-content: space-between;">
                    <strong>@message.Subject</strong>
                    <small>@message.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <p style="margin: 4px 0;">@message.Content</p>
                @if (!message.IsRead)
                {
                    <button @onclick="() => MarkAsRead(message.Id)">Marker som læst</button>
                }
            </li>
        }
    </ul>
}

@code {
    private List<MessageDto>? messages;

    // TODO
    // Hardcodet — skal erstattes med rigtigt id
    private Guid receiverId = Guid.Parse("00000000-0000-0000-0000-000000000001");

    protected override async Task OnInitializedAsync()
    {
        messages = await MessageService.GetAllMessagesAsync(receiverId);
    }

    private async Task MarkAsRead(Guid messageId)
    {
        await MessageService.MarkAsReadAsync(messageId);
        messages = await MessageService.GetAllMessagesAsync(receiverId);
    }
}