    {
      "name": "Login request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Login with test-credentials. Returns and saves token as a collection variable\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "//Saves jsons-response as a local variable\r",
              "const response = pm.response.json();\r",
              "\r",
              "//Verify that the login response doesnt contain undefined token value.\r",
              "pm.test(\"JWT token exists\", function () {\r",
              "     pm.expect(response.token).to.not.be.undefined; \r",
              "     });\r",
              "\r",
              "//Sets the JWT token as a collection variable for future requests\r",
              "pm.collectionVariables.set(\"jwt\", response.token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"test.testesen@fitlife.local\",\r\n    \"password\": \"Test1234!\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/auth/Login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "auth",
            "Login"
          ]
        }
      },
      "response": []
    },
    {
